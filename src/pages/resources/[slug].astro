---
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const resources = import.meta.glob("../../content/resources/*.md", { eager: true });
  return Object.entries(resources).map(([path, resource]) => ({
    params: { slug: path.split("/").pop()?.replace(/\.md$/, "") },
    props: { resource }
  }));
}

const { resource } = Astro.props;
const { Content, frontmatter } = resource;
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="article">
    <header>
      <p class="eyebrow">资料</p>
      <h1>{frontmatter.title}</h1>
      <p class="lead">{frontmatter.description}</p>
      <p class="meta">{frontmatter.date} · {(frontmatter.language ?? "zh").toUpperCase()}</p>
    </header>
    <div class="article-content">
      <Content />
    </div>
  </article>
</BaseLayout>
