---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { entriesByTag } from "@/lib/content";
---

<BaseLayout title="标签" description="藏书小刊的标签索引。">
  <section class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">Tags</p>
        <h1>标签</h1>
        <p>按标签浏览博客、动态、资料、收藏和下载。</p>
      </div>
    </div>
    <div class="tag-cloud">
      {entriesByTag.map(({ tag, entries }) => (
        <a class="tag" href={`#${encodeURIComponent(tag)}`}>{tag} · {entries.length}</a>
      ))}
    </div>
    <div class="tag-sections">
      {entriesByTag.map(({ tag, entries }) => (
        <section id={encodeURIComponent(tag)} class="tag-section">
          <h2>{tag}</h2>
          <div class="list">
            {entries.map((entry) => (
              <article class="list-item">
                <div class="meta">{entry.sectionLabel} · {entry.date}</div>
                <h3><a href={entry.url}>{entry.title}</a></h3>
                <p>{entry.description}</p>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
