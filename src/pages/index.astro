---
import EntryCard from "@/components/EntryCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { latestEntries } from "@/lib/content";

const sections = [
  { href: "/research/", title: "研究", text: "研究文章、项目说明、PDF、数据、代码和补充材料。" },
  { href: "/blog/", title: "博客", text: "较完整的文章、观点和技术整理。" },
  { href: "/essays/", title: "随笔", text: "短想法、观察、记录和日常片段。" },
  { href: "/resources/", title: "资料", text: "文档索引、教程、研究材料和知识库入口。" },
  { href: "/downloads/", title: "下载", text: "可直接获取的文件、模板、PDF 和资料包。" },
  { href: "/submit/", title: "投稿", text: "外部文章和资料的提交入口，先进入审核流程。" }
];

const homeLatestEntries = latestEntries.filter((entry) => entry.section !== "bookmarks");
---

<BaseLayout>
  <section class="container hero">
    <div>
      <p class="eyebrow">Personal research journal</p>
      <h1>藏书小刊</h1>
      <p class="lead">
        一个简约快速的个人研究小刊，用来发布研究文章、博客、随笔动态、资料索引与可下载附件。
      </p>
    </div>
  </section>

  <section class="container">
    <div class="section-head">
      <div>
        <h2>栏目</h2>
      </div>
    </div>
    <div class="grid section-grid">
      {sections.map((section) => (
        <article class="card section-card">
          <h3><a href={section.href}>{section.title}</a></h3>
          <p>{section.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container">
    <div class="section-head">
      <div>
        <h2>最新更新</h2>
        <p>所有栏目内容都会按时间自动汇总到这里。</p>
      </div>
    </div>
    <div class="grid">
      {homeLatestEntries.map((entry) => <EntryCard entry={entry} />)}
    </div>
  </section>
</BaseLayout>
