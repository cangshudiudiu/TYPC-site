---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { essays } from "@/lib/content";
---

<BaseLayout title="随笔" description="Essays and notes from cangshuzhijia.">
  <section class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">Essays</p>
        <h1>随笔</h1>
        <p>短想法、观察、记录和日常片段。</p>
      </div>
    </div>
    <div class="list">
      {essays.map((essay) => (
        <article class="list-item">
          <div class="meta">{essay.date} · {(essay.language ?? "zh").toUpperCase()}</div>
          <h2><a href={essay.url}>{essay.title}</a></h2>
          <p>{essay.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
